# Admin Configuration
# Email-urile adminilor separate prin virgulă (ex: admin@example.com,admin2@example.com)
# Alternativ, poți seta role='admin' în app_metadata sau user_metadata pentru utilizatori în Supabase
ADMIN_EMAILS=admin@example.com

# PartyKit Configuration (for real-time collaboration)
# For local development: localhost:1999
# For production: your-partykit-project.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999